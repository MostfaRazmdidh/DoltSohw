  dialog: "\u0627\u0645\u0631\u0648\u0632 \u0645\u0631\u062F\u0645 \u0628\u0631\u0627\u06CC
    \u0627\u0646\u062A\u062E\u0627\u0628\u0627\u062A \u0631\u0626\u06CC\u0633 \u062F\u0648\u0644\u062A
